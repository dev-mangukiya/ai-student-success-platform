# --- Data (raw dataset can be large; keep small samples only) ---
data/raw/*.csv
data/processed/*.csv
!data/raw/.gitkeep
!data/processed/.gitkeep

# --- Vector store (rebuilt from knowledge base at runtime) ---
ai/rag/vector_store/

# --- OS / editor ---
.DS_Store
.vscode/
.idea/

