# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# --- Environment / secrets ---
.env

# --- Logs ---
logs/
*.log

# --- ML artifacts (kept out of git; regenerated by pipeline) ---
artifacts/models/*.pkl
artifacts/preprocessors/*.pkl
